# Supabase — pegar em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Nunca expor no client — apenas em Server Components e Edge Functions
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Asaas — pegar em: https://www.asaas.com/userConfig/index (Integrações → Chave de API)
# Use ASAAS_ENV=sandbox para testes, production para produção
ASAAS_ENV=sandbox
ASAAS_API_KEY=$aact_sua_chave_aqui
ASAAS_WEBHOOK_TOKEN=token_secreto_que_voce_define_no_painel_asaas

# URL da aplicação (Vercel coloca automaticamente em produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000
